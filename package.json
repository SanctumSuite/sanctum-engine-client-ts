{
  "name": "sanctum-engine-client",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript client for Sanctum Engine — the LLM service layer of the Sanctum Suite.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SanctumSuite/sanctum-engine-client-ts.git"
  },
  "homepage": "https://github.com/SanctumSuite/sanctum-engine-client-ts",
  "license": "Apache-2.0",
  "keywords": [
    "sanctum",
    "llm",
    "ollama",
    "openrouter",
    "ai"
  ]
}
